# Copy this file to .env and fill in your values. Do not commit .env.
# cp .env.example .env

# Required: your S3 bucket name (create one in AWS Console → S3)
AWS_BUCKET_NAME=abwat-test

# Optional: base URL for view links (default http://localhost:8080)
# VIEW_LINK_BASE_URL=http://localhost:8080

# AWS credentials are read from the terminal (see BACKEND_SETUP.md):
# Run: aws configure
# Or set here (do not commit):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
