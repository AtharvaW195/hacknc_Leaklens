{
    "manifest_version": 3,
    "name": "Privacy Guardrail",
    "version": "1.0",
    "description": "Real-time privacy and security guardrail to prevent data leaks and ensure safe browsing.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>",
        "http://localhost:8080/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Privacy Guardrail"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "malicious_domains.json"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}