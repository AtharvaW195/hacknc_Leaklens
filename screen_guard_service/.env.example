# ==========================================
# Screen Guard Service - Environment Config
# ==========================================

# ---- Core runtime behavior ----
MONITOR_MODE=auto
MONITOR_PLATFORMS=zoom,slack
MONITOR_SCAN_INTERVAL=1.5
MONITOR_CHECK_INTERVAL=3
MONITOR_MIN_CONFIDENCE=0.80
MONITOR_FOCUS_PROFILE=pii_full
MONITOR_ENSEMBLE_ALL=true
MONITOR_ENABLE_DESKTOP_NOTIFICATIONS=false
MONITOR_TARGET_OS=auto
MONITOR_OUTPUT_DIR=monitor_output

# ---- Optional runtime toggles ----
MONITOR_CPU_ONLY=false
MONITOR_DISABLE_ADAPTIVE_CONTEXT=false
MONITOR_DISABLE_BERT_ENRICHMENT=false

# ---- Model/runtime credentials ----
HF_TOKEN=

# ---- Optional integration credentials ----
OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GOOGLE_API_KEY=
GITHUB_TOKEN=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
